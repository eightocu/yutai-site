---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IconHeading from "../../components/IconHeading.astro";
import {
  getCategoryNodeHref,
  getBenefitsByCategory,
  getCategoryDefinitions,
  slugifyCategory,
} from "../../lib/benefits";

function getIconName(name, major) {
  if (/QUO|ギフトカード|グルメカード|図書カード|おこめ券|ポイント|電子マネー|暗号資産|仮想通貨|デジタルギフト/.test(name)) {
    return "card";
  }

  if (/優待券|割引券|ファミレス|焼肉|ハンバーグ|ファストフード|カフェ|居酒屋|中華|ラーメン/.test(name)) {
    return "ticket";
  }

  if (/飲料|お米|麺類|お肉|お菓子|果物|フルーツ|野菜|魚介|調味料|飲食料品|食品|サプリ/.test(name)) {
    return "food";
  }

  if (/美容|化粧品|アクセサリー|衣類|ファッション/.test(name)) {
    return "sparkle";
  }

  if (/家庭用品|紙製品|文房具|日用品|雑貨|カレンダー/.test(name)) {
    return "home";
  }

  if (/カタログギフト/.test(name) || /カタログギフト/.test(major)) {
    return "gift";
  }

  if (/旅行|宿泊|ホテル|遊園地|テーマパーク|温泉|映画|演劇|イベント|ゴルフ|フィットネス|スポーツ|乗り物/.test(name)) {
    return "leisure";
  }

  if (/寄付|社会貢献|限定品|カテゴリにはまらない|資産・金融/.test(name) || /その他/.test(major)) {
    return "star";
  }

  return "circle";
}

function getIconTone(major) {
  if (major === "金券・ポイント") return "peach";
  if (major === "割引券・優待券") return "rose";
  if (major === "飲食料品") return "gold";
  if (major === "日用品") return "sky";
  if (major === "カタログギフト") return "violet";
  return "gray";
}

function renderIcon(iconName) {
  switch (iconName) {
    case "card":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><rect x="3.5" y="6" width="17" height="12" rx="2.5"></rect><path d="M3.5 10h17"></path><path d="M7 14h4"></path></svg>`;
    case "ticket":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="M6 7h12a2 2 0 0 1 2 2v2a2 2 0 0 0 0 4v2a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2a2 2 0 0 0 0-4V9a2 2 0 0 1 2-2Z"></path><path d="M12 7v10"></path></svg>`;
    case "food":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="M7 4v7"></path><path d="M10 4v7"></path><path d="M7 8h3"></path><path d="M8.5 11v9"></path><path d="M15 4v16"></path><path d="M15 4c2 1.2 3 3.2 3 5.6 0 1.7-.6 3-1.7 4"></path></svg>`;
    case "home":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="M4 11.5 12 5l8 6.5"></path><path d="M6.5 10.5V19h11v-8.5"></path><path d="M10 19v-5h4v5"></path></svg>`;
    case "gift":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="M4 10h16v10H4z"></path><path d="M12 10v10"></path><path d="M4 14h16"></path><path d="M12 10c-2.8 0-4.5-1-4.5-2.8S9 4.5 10.5 5c1.3.4 1.8 2.1 1.5 5Z"></path><path d="M12 10c2.8 0 4.5-1 4.5-2.8S15 4.5 13.5 5c-1.3.4-1.8 2.1-1.5 5Z"></path></svg>`;
    case "sparkle":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="m12 4 1.5 4.5L18 10l-4.5 1.5L12 16l-1.5-4.5L6 10l4.5-1.5Z"></path><path d="m18.5 4 .7 2 .8.7-2 .7-.7 2-.7-2-2-.7 2-.7Z"></path></svg>`;
    case "leisure":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="M5 18.5 18.5 5"></path><path d="M7.5 5H19v11.5"></path><path d="M5 8.5V19h10.5"></path></svg>`;
    case "star":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><path d="m12 4 2.4 4.9 5.4.8-3.9 3.8.9 5.4L12 16.3 7.2 19l.9-5.4L4.2 9.7l5.4-.8Z"></path></svg>`;
    default:
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"><circle cx="12" cy="12" r="6"></circle></svg>`;
  }
}

const categories = getCategoryDefinitions().map((category) => ({
  name: category.name,
  href: `/categories/${slugifyCategory(category.name)}/`,
  count: getBenefitsByCategory(category.name).length,
  major: category.major,
  middle: category.middle,
  icon: getIconName(category.name, category.major),
  tone: getIconTone(category.major),
}));

const groupedCategories = Array.from(
  categories.reduce((map, category) => {
    const current = map.get(category.major) || [];
    current.push(category);
    map.set(category.major, current);
    return map;
  }, new Map()),
);

const pageTitle = "株主優待 カテゴリ一覧 | よくわかる株主優待";
const pageDescription = "株主優待をカテゴリ別に一覧で確認できます。気になるカテゴリから対象銘柄へ進めます。";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-header">
    <IconHeading level="h1" text="株主優待 カテゴリ一覧" variant="category" />
  </section>

  {groupedCategories.map(([group, items]) => (
    <section class="group-section">
      <div class="group-heading">
        <h2>
          <a href={getCategoryNodeHref({ level: "major", name: group, major: group })}>
            {group}
          </a>
        </h2>
        <p>{items.length}カテゴリ</p>
      </div>

      {Array.from(
        items.reduce((map, category) => {
          const key = category.middle || "";
          const current = map.get(key) || [];
          current.push(category);
          map.set(key, current);
          return map;
        }, new Map()),
      ).map(([middle, middleItems]) => (
        <div class="middle-section">
          {middle && (
            <h3 class="middle-heading">
              <a href={getCategoryNodeHref({ level: "middle", name: middle, major: group, middle })}>
                {middle}
              </a>
            </h3>
          )}

          <div class="category-grid">
            {middleItems.map((category) => (
              <a class="category-card" href={category.href}>
                <div class="category-card-head">
                  <span class:list={["category-icon", `category-icon-${category.tone}`]}>
                    <Fragment set:html={renderIcon(category.icon)} />
                  </span>
                  <h4>{category.name}</h4>
                </div>
                <p>{category.count}件</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  ))}
</BaseLayout>

<style>
  .page-header {
    padding: 8px 0 26px;
  }

  h1 {
    margin: 0;
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.2;
    color: var(--text);
  }

  .group-section + .group-section {
    margin-top: 36px;
  }

  .group-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }

  .group-heading h2 {
    margin: 0;
    font-size: 24px;
    line-height: 1.4;
    color: var(--text);
  }

  .group-heading h2 a,
  .middle-heading a {
    color: inherit;
  }

  .group-heading p {
    margin: 0;
    color: var(--soft);
    font-size: 14px;
  }

  .middle-section + .middle-section {
    margin-top: 24px;
  }

  .middle-heading {
    margin: 0 0 12px;
    font-size: 16px;
    color: var(--soft);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .category-card {
    display: block;
    padding: 24px;
    border-radius: var(--radius-md);
    background: var(--surface);
    border: 1px solid var(--line);
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .category-card:hover {
    border-color: var(--line-strong);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
  }

  .category-card-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .category-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    color: var(--soft);
    flex-shrink: 0;
  }

  .category-icon-peach {
    background: #fff1ea;
    border-color: #f3cfbf;
    color: #cf7d59;
  }

  .category-icon-rose {
    background: #fff0f4;
    border-color: #f0ced8;
    color: #c16b85;
  }

  .category-icon-gold {
    background: #fff7e7;
    border-color: #f0dfb3;
    color: #b38a2f;
  }

  .category-icon-sky {
    background: #eef6fb;
    border-color: #cfe0ea;
    color: #5d88a1;
  }

  .category-icon-violet {
    background: #f4f0fb;
    border-color: #ddd0f0;
    color: #8163b1;
  }

  .category-icon-gray {
    background: #f4f4f4;
    border-color: #dddddd;
    color: #7a7a7a;
  }

  .category-icon svg {
    width: 20px;
    height: 20px;
  }

  .category-card h4 {
    margin: 0;
    font-size: 20px;
    color: var(--text);
    line-height: 1.4;
  }

  .category-card p {
    margin: 0;
    color: var(--soft);
    font-size: 14px;
  }
</style>
