---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IconHeading from "../../components/IconHeading.astro";
import {
  formatJapaneseDate,
  formatPercent,
  formatPrice,
  getAllBenefits,
  getBenefitIntroComment,
  getCategoryNodeHref,
  getCategoryNodesForItem,
  getCompanyOverviewSections,
  parseBenefitDetails,
} from "../../lib/benefits";

export async function getStaticPaths() {
  return getAllBenefits().map((item) => ({
    params: { slug: item.company_code },
    props: { item },
  }));
}

const { item } = Astro.props;
const categoryNodes = getCategoryNodesForItem(item);
const benefitDetailBlocks = parseBenefitDetails(item.benefit_details);
const dividendYield = item.dividend_yield_forecast || item.forecast_dividend_yield;
const totalYield = item.total_yield_forecast || item.forecast_total_yield;
const { companyOverview } = getCompanyOverviewSections(item);
const benefitIntroComment = getBenefitIntroComment(item);
const benefitIntroParagraphs = benefitIntroComment
  .split(/\n+/)
  .map((text) => text.trim())
  .filter(Boolean);
const priceAsOf = formatJapaneseDate(item.updated_at);

function groupBenefitRows(rows) {
  const groups = [];
  let currentGroup = null;

  for (const row of rows) {
    if (row.type === "condition" || row.type === "subheading") {
      currentGroup = {
        leader: row,
        items: [],
      };
      groups.push(currentGroup);
      continue;
    }

    if ((row.type === "item" || row.type === "note") && currentGroup) {
      currentGroup.items.push(row);
      continue;
    }

    groups.push({
      leader: row,
      items: [],
    });
    currentGroup = null;
  }

  return groups;
}

const pageTitle = `${item.company_name}(${item.company_code})の株主優待 | よくわかる株主優待`;
const pageDescription = `${item.company_name}の株主優待について、権利確定月、最低必要株数、優待内容、最低取得額などをまとめています。`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="stock-detail">
    <header class="hero">
      <div class="hero-main">
        <p class="code">{item.company_code}</p>
        <IconHeading level="h1" text={item.company_name} variant="detail" />
        {categoryNodes.length > 0 && (
          <div class="category-links">
            {categoryNodes.map((category) => (
              <a
                class:list={["category-link", `category-link-${category.level}`]}
                href={getCategoryNodeHref(category)}
              >
                {category.name}
              </a>
            ))}
          </div>
        )}
      </div>

      <aside class="hero-side">
        <p class="side-label">権利確定月</p>
        <p class="side-value">{item.record_month || "-"}</p>
        <p class="side-label">最低取得額</p>
        <p class="side-value side-value-small">{formatPrice(item.minimum_purchase_amount)}</p>
        <p class="hero-note">※ 株価・最低取得額は {priceAsOf} 時点</p>
      </aside>
    </header>

    <section class="content-section">
      <h2>株主優待の内容</h2>
      {benefitDetailBlocks.length > 0 ? (
        <div class="benefit-detail-list">
          {benefitDetailBlocks.map((block) => (
            <section class="benefit-block">
              {block.label && (
                <p class:list={[
                  "benefit-block-label",
                  block.labelType === "period" && "benefit-block-label-period",
                ]}>
                  {block.label}
                </p>
              )}

              {block.rows.length > 0 && (
                <div class="benefit-rows">
                  {groupBenefitRows(block.rows).map((group) => (
                    <div class="benefit-group">
                      <div class:list={["benefit-row", `benefit-row-${group.leader.type}`]}>
                        {group.leader.text}
                      </div>

                      {group.items.length > 0 && (
                        <ul class="benefit-subrows">
                          {group.items.map((row) => (
                            <li class:list={["benefit-row", "benefit-subrow", `benefit-row-${row.type}`]}>
                              {row.text}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      ) : (
        <p>-</p>
      )}
    </section>

    <section class="info-grid">
      <div class="info-card">
        <h2>基本情報</h2>
        <p class="data-note">※ 株価と最低取得額は {priceAsOf} 時点のデータです。</p>
        <dl>
          <dt>市場</dt>
          <dd>{item.listed_market || "-"}</dd>

          <dt>業種</dt>
          <dd>{item.industry || "-"}</dd>

          <dt>株価</dt>
          <dd>{formatPrice(item.stock_price)}</dd>

          <dt>最低必要株数</dt>
          <dd>{item.minimum_shares || "-"}</dd>

          <dt>最低取得額</dt>
          <dd>{formatPrice(item.minimum_purchase_amount)}</dd>

          <dt>優待回数</dt>
          <dd>{item.benefit_frequency || "-"}</dd>
        </dl>
      </div>

      <div class="info-card">
        <h2>権利確定情報</h2>
        <dl>
          <dt>権利確定月</dt>
          <dd>{item.record_month || "-"}</dd>

          <dt>権利確定日</dt>
          <dd>{formatJapaneseDate(item.record_date)}</dd>

          <dt>長期保有条件</dt>
          <dd>{item.long_term_holding_requirement || "-"}</dd>

          <dt>更新日</dt>
          <dd>{formatJapaneseDate(item.updated_at)}</dd>
        </dl>
      </div>

      <div class="info-card">
        <h2>利回り情報</h2>
        <dl>
          <dt>配当利回り（予想）</dt>
          <dd>{formatPercent(dividendYield)}</dd>

          <dt>優待利回り</dt>
          <dd>{formatPercent(item.benefit_yield)}</dd>

          <dt>総合利回り（予想）</dt>
          <dd>{formatPercent(totalYield)}</dd>

          <dt>優待の価値</dt>
          <dd>{formatPrice(item.benefit_value)}</dd>
        </dl>
      </div>
    </section>

    <section class="content-section">
      <h2>利用方法</h2>
      <p>{item.usage_method || "-"}</p>
    </section>

    <section class="content-section">
      <h2>会社概要</h2>
      <p>{companyOverview || item.company_overview || "-"}</p>
    </section>

    <section class="content-section">
      <h2>株主優待 紹介コメント</h2>
      {benefitIntroParagraphs.length > 0 ? (
        <div class="long-comment">
          {benefitIntroParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      ) : (
        <p>-</p>
      )}
    </section>

    <section class="content-section">
      <h2>関連リンク</h2>
      <ul class="link-list">
        {item.official_ir_url && (
          <li><a href={item.official_ir_url} target="_blank" rel="noreferrer">公式IR</a></li>
        )}
        {item.disclosure_url && (
          <li><a href={item.disclosure_url} target="_blank" rel="noreferrer">開示情報</a></li>
        )}
        {item.reference_url && (
          <li><a href={item.reference_url} target="_blank" rel="noreferrer">参考URL</a></li>
        )}
      </ul>
    </section>

    <section class="content-section">
      <h2>変更履歴</h2>
      <p>{item.change_history || "-"}</p>
    </section>
  </article>
</BaseLayout>

<style>
  .stock-detail {
    padding: 12px 0 48px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(250px, 0.7fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .hero-main,
  .hero-side {
    padding: 30px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .hero-side {
    display: grid;
    align-content: start;
  }

  .code {
    margin: 0 0 8px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0 0 12px;
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.22;
    color: var(--text);
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
  }

  .category-link {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
  }

  .category-link-major {
    background: var(--surface);
    color: var(--text);
  }

  .category-link-middle {
    background: #f4f5f4;
  }

  .side-label {
    margin: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--soft);
  }

  .side-value {
    margin: 6px 0 18px;
    font-size: 34px;
    line-height: 1.1;
    color: var(--text);
  }

  .side-value-small {
    font-size: 26px;
    margin-bottom: 0;
  }

  .hero-note {
    margin: 14px 0 0;
    color: #8b948c;
    font-size: 12px;
    line-height: 1.6;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .info-card {
    padding: 26px;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .info-card h2 {
    margin: 0 0 16px;
    font-size: 20px;
    color: var(--text);
  }

  .data-note {
    margin: -2px 0 16px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--soft);
  }

  dl {
    margin: 0;
  }

  dt {
    margin-top: 12px;
    font-weight: 700;
    color: var(--soft);
    font-size: 13px;
  }

  dt:first-child {
    margin-top: 0;
  }

  dd {
    margin: 4px 0 0;
    color: var(--text);
  }

  .content-section {
    margin-top: 28px;
    padding: 30px;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .content-section h2 {
    margin: 0 0 14px;
    color: var(--text);
    font-size: 24px;
  }

  .content-section p {
    white-space: pre-line;
    color: var(--muted);
  }

  .long-comment {
    display: grid;
    gap: 14px;
  }

  .long-comment p {
    margin: 0;
    line-height: 1.95;
  }

  .benefit-detail-list {
    display: grid;
    gap: 18px;
  }

  .benefit-block {
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--surface-soft);
  }

  .benefit-block-label {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .benefit-block-label-period {
    color: var(--soft);
  }

  .benefit-rows {
    display: grid;
    gap: 10px;
  }

  .benefit-group {
    display: grid;
    gap: 8px;
  }

  .benefit-row {
    padding-left: 18px;
    position: relative;
    color: var(--muted);
    line-height: 1.8;
  }

  .benefit-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.8em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--line-strong);
    transform: translateY(-50%);
  }

  .benefit-row-subheading,
  .benefit-row-condition {
    padding-left: 0;
    font-weight: 700;
    color: var(--text);
  }

  .benefit-row-subheading::before,
  .benefit-row-condition::before {
    display: none;
  }

  .benefit-row-note {
    padding: 0;
    color: var(--soft);
    font-size: 14px;
    line-height: 1.7;
  }

  .benefit-row-note::before {
    display: none;
  }

  .benefit-subrows {
    margin: 0 0 0 18px;
    padding: 0 0 0 14px;
    list-style: none;
    border-left: 1px solid var(--line);
    display: grid;
    gap: 8px;
  }

  .benefit-subrow {
    padding-left: 0;
    font-size: 15px;
  }

  .benefit-subrow::before {
    display: none;
  }

  .link-list {
    margin: 0;
    padding-left: 18px;
  }

  .link-list li + li {
    margin-top: 8px;
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-main,
    .hero-side {
      padding: 24px;
      border-radius: 24px;
    }
  }
</style>
