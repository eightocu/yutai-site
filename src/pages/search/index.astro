---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IconHeading from "../../components/IconHeading.astro";
import { formatPrice, getAllBenefits } from "../../lib/benefits";

const searchIndex = getAllBenefits().map((item) => ({
  company_code: item.company_code,
  company_name: item.company_name,
  benefit_category: item.benefit_category,
  record_month: item.record_month,
  minimum_purchase_amount: formatPrice(item.minimum_purchase_amount),
}));

const pageTitle = "株主優待を検索 | よくわかる株主優待";
const pageDescription = "企業名や銘柄コード、カテゴリ名から株主優待を検索できます。";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-header">
    <IconHeading level="h1" text="株主優待を検索" variant="search" />
    <p>企業名、銘柄コード、カテゴリ名で検索できます。</p>
  </section>

  <section class="search-box">
    <form id="search-form">
      <input id="search-input" name="q" type="search" placeholder="例: QUOカード / 3662 / イオン" />
      <button type="submit">検索</button>
    </form>
  </section>

  <section class="results-section">
    <p id="search-status" class="status">キーワードを入力して検索してください。</p>
    <div id="search-results" class="result-grid"></div>
  </section>
</BaseLayout>

<script define:vars={{ searchIndex }}>
  const input = document.querySelector("#search-input");
  const form = document.querySelector("#search-form");
  const status = document.querySelector("#search-status");
  const results = document.querySelector("#search-results");
  const params = new URLSearchParams(window.location.search);

  const render = (query) => {
    const q = query.trim().toLowerCase();

    if (!q) {
      status.textContent = "キーワードを入力して検索してください。";
      results.innerHTML = "";
      return;
    }

    const matched = searchIndex.filter((item) =>
      [item.company_code, item.company_name, item.benefit_category, item.record_month]
        .filter(Boolean)
        .some((value) => value.toLowerCase().includes(q)),
    ).slice(0, 50);

    status.textContent = `${matched.length}件見つかりました。`;

    results.innerHTML = matched.map((item) => `
      <a class="result-card" href="/stocks/${item.company_code}/">
        <div class="card-top">
          <p class="code">${item.company_code}</p>
          <span class="month-pill">${item.record_month || "-"}</span>
        </div>
        <h2>${item.company_name}</h2>
        <p class="category">${item.benefit_category || "-"}</p>
        <p class="amount">最低取得額: ${item.minimum_purchase_amount || "-"}</p>
      </a>
    `).join("");
  };

  input.value = params.get("q") || "";
  render(input.value);

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    const q = input.value.trim();
    const next = new URL(window.location.href);
    if (q) {
      next.searchParams.set("q", q);
    } else {
      next.searchParams.delete("q");
    }
    history.replaceState({}, "", next);
    render(q);
  });
</script>

<style>
  .page-header {
    padding: 8px 0 24px;
    max-width: 760px;
  }

  h1 {
    margin: 0 0 10px;
    font-size: clamp(36px, 6vw, 56px);
    line-height: 1.2;
    color: var(--text);
  }

  .page-header p {
    margin: 0;
    color: var(--muted);
    font-size: 18px;
  }

  .search-box {
    padding-bottom: 24px;
  }

  form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  input {
    flex: 1 1 320px;
    min-height: 48px;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    font: inherit;
    color: var(--text);
    background: var(--surface);
  }

  button {
    min-height: 48px;
    padding: 0 18px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .status {
    margin: 0 0 16px;
    color: var(--muted);
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  :global(.result-card) {
    display: block;
    padding: 24px;
    border-radius: var(--radius-md);
    background: var(--surface);
    border: 1px solid var(--line);
    color: inherit;
  }

  :global(.result-card:hover) {
    border-color: var(--line-strong);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
  }

  :global(.result-card h2) {
    margin: 10px 0 8px;
    font-size: 24px;
    line-height: 1.45;
    color: var(--text);
  }

  :global(.card-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  :global(.code) {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  :global(.month-pill) {
    padding: 8px 10px;
    border-radius: 999px;
    background: var(--surface-soft);
    color: var(--accent);
    font-size: 13px;
    font-weight: 700;
  }

  :global(.category) {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 15px;
  }

  :global(.amount) {
    margin: 0;
    color: var(--text);
    font-weight: 700;
  }
</style>
