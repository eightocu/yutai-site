---
interface Props {
  level?: "h1" | "h2";
  text: string;
  variant?:
    | "sparkle"
    | "calendar"
    | "category"
    | "search"
    | "filter"
    | "guide"
    | "list"
    | "bookmark"
    | "detail";
  class?: string;
}

const {
  level = "h2",
  text,
  variant = "sparkle",
  class: className = "",
} = Astro.props;

const Tag = level;

function getIconSvg(name: string) {
  switch (name) {
    case "calendar":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5.5" width="16" height="14" rx="3"/><path d="M8 4v3"/><path d="M16 4v3"/><path d="M4 10h16"/><path d="M8 13h3"/><path d="M13 13h3"/></svg>`;
    case "category":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 7h6v6H5z"/><path d="M13 7h6v4h-6z"/><path d="M13 13h6v4h-6z"/><path d="M5 15h6v2H5z"/></svg>`;
    case "search":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="5.5"/><path d="m16 16 4 4"/></svg>`;
    case "filter":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M7 12h10"/><path d="M10 18h4"/></svg>`;
    case "guide":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 5.5h9a3 3 0 0 1 3 3V19H9a3 3 0 0 0-3 3z"/><path d="M6 5.5V22"/><path d="M9.5 10h5"/><path d="M9.5 13.5h5"/></svg>`;
    case "list":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 7h10"/><path d="M9 12h10"/><path d="M9 17h10"/><circle cx="5.5" cy="7" r="1"/><circle cx="5.5" cy="12" r="1"/><circle cx="5.5" cy="17" r="1"/></svg>`;
    case "bookmark":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5h10a2 2 0 0 1 2 2v12l-7-4-7 4V7a2 2 0 0 1 2-2z"/></svg>`;
    case "detail":
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="4.5" width="14" height="15" rx="3"/><path d="M9 9h6"/><path d="M9 12.5h6"/><path d="M9 16h4"/></svg>`;
    default:
      return `<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 5 1.8 3.8L18 9.4l-3 2.9.7 4.1-3.7-2.1-3.7 2.1.7-4.1-3-2.9 4.2-.6Z"/></svg>`;
  }
}
---

<Tag class:list={["icon-heading", `icon-heading-${level}`, className]}>
  <span class="icon-heading-mark" set:html={getIconSvg(variant)} />
  <span>{text}</span>
</Tag>

<style>
  .icon-heading {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .icon-heading-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #fff1f5;
    border: 1px solid #f3d4df;
    color: #c97791;
    flex-shrink: 0;
  }

  .icon-heading-h1 .icon-heading-mark {
    width: 42px;
    height: 42px;
  }

  .icon-heading-mark :global(svg) {
    width: 18px;
    height: 18px;
  }

  .icon-heading-h1 .icon-heading-mark :global(svg) {
    width: 20px;
    height: 20px;
  }
</style>
